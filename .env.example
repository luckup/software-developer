# API base URL (optional). Leave empty so /api/contact hits this app (Vercel function or Vite dev plugin).
# Only set if your Express API runs on another host, e.g. VITE_API_URL=https://api.moonsofts.net
VITE_API_URL=

# Contact form email (used by Vite dev + Vercel — NOT exposed to the browser; no VITE_ prefix)
CONTACT_TO_EMAIL=yuji@moonsofts.net
RESEND_API_KEY=
# Verified sender in Resend (use onboarding@resend.dev until moonsofts.net domain is verified)
SMTP_FROM=MoonSofts <onboarding@resend.dev>

# --- CDN images (required for production build & recommended for dev) ---
# Upload workflow:
#   1. Put PNGs in src/assets/ (gitignored — only on your machine)
#   2. npm run cdn:prepare
#   3. Upload cdn-upload/ to Cloudflare R2, AWS S3, etc.
#   4. Set your public CDN URL below (no trailing slash)
#
# Vercel Blob (moonsoftsnet public store — upload with npm run vercel:blob:upload)
#   VITE_CDN_BASE_URL=https://kmbR6bCYbcA9kB47.public.blob.vercel-storage.com
# Other CDNs:
#   VITE_CDN_BASE_URL=https://pub-xxxxx.r2.dev/moonsofts
VITE_CDN_BASE_URL=https://kmbR6bCYbcA9kB47.public.blob.vercel-storage.com

# Required only for npm run vercel:blob:upload (from Vercel → Storage → Blob → token)
# BLOB_READ_WRITE_TOKEN=

# Optional: use bundled local assets in dev only (requires files in src/assets/)
# VITE_USE_LOCAL_ASSETS=true
